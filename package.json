{
  "name": "oagen",
  "version": "0.0.1",
  "description": "Generate SDKs from OpenAPI 3.1 specifications",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "oagen": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:structure": "tsx scripts/lint-structure.ts",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt --write .",
    "fix": "oxlint --fix && oxfmt --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "smoke:raw": "tsx scripts/smoke/raw.ts",
    "smoke:sdk:node": "tsx scripts/smoke/sdk-node.ts",
    "smoke:diff": "tsx scripts/smoke/diff.ts",
    "smoke": "tsx scripts/smoke/sdk-test.ts",
    "smoke:baseline": "tsx scripts/smoke/baseline.ts",
    "smoke:validate": "tsx scripts/smoke/validate.ts",
    "compat:extract": "tsx scripts/compat-extract.ts"
  },
  "dependencies": {
    "@redocly/openapi-core": "^1.34.3",
    "commander": "^13.1.0",
    "typescript": "^5.7.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "dotenv": "^17.3.1",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0"
  }
}
